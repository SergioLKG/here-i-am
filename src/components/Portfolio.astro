---

---

<div class="flex flex-col min-h-[100dvh]">
  <header class="px-4 lg:px-6 h-14 flex items-center bg-background">
    <a class="flex items-center justify-center" href="#" rel="ugc">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="h-6 w-6 text-primary"
      >
        <path d="m8 3 4 8 5-5 5 15H2L8 3z"></path>
      </svg>
      <span class="sr-only">Portfolio</span>
    </a>
    <nav class="ml-auto flex gap-4 sm:gap-6">
      <a
        class="text-sm font-medium hover:underline underline-offset-4 text-primary-foreground"
        href="#"
        rel="ugc"
      >
        Experience
      </a>
      <a
        class="text-sm font-medium hover:underline underline-offset-4 text-primary-foreground"
        href="#"
        rel="ugc"
      >
        Projects
      </a>
      <a
        class="text-sm font-medium hover:underline underline-offset-4 text-primary-foreground"
        href="#"
        rel="ugc"
      >
        About
      </a>
      <a
        class="text-sm font-medium hover:underline underline-offset-4 text-primary-foreground"
        href="#"
        rel="ugc"
      >
        Contact
      </a>
    </nav>
  </header>
  <main class="flex-1">
    <section id="hero" class="w-full py-12 md:py-24 lg:py-32 bg-background">
      <div class="container px-4 md:px-6">
        <div
          class="grid gap-6 lg:grid-cols-[1fr_400px] lg:gap-12 xl:grid-cols-[1fr_600px]"
        >
          <div class="flex flex-col justify-center space-y-4">
            <div class="space-y-2">
              <h1
                class="text-3xl font-bold tracking-tighter sm:text-5xl xl:text-6xl/none text-primary-foreground"
              >
                <div></div>
              </h1>
              <p class="max-w-[600px] text-muted-foreground md:text-xl">
                I specialize in building responsive and accessible web
                applications using the latest technologies and best practices.
              </p>
            </div>
            <div class="flex flex-col gap-2 min-[400px]:flex-row">
              <a
                class="inline-flex h-10 items-center justify-center rounded-md bg-primary px-8 text-sm font-medium text-primary-foreground shadow transition-colors hover:bg-primary/90 focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring disabled:pointer-events-none disabled:opacity-50"
                href="#"
                rel="ugc"
              >
                View Projects
              </a>
              <a
                class="inline-flex h-10 items-center justify-center rounded-md border border-input bg-background px-8 text-sm font-medium shadow-sm transition-colors hover:bg-accent hover:text-accent-foreground focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring disabled:pointer-events-none disabled:opacity-50"
                href="#"
                rel="ugc"
              >
                Get in Touch
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>
    <section id="experience" class="w-full py-12 md:py-24 lg:py-32 bg-muted">
      <div class="container px-4 md:px-6">
        <div
          class="flex flex-col items-center justify-center space-y-4 text-center"
        >
          <div class="space-y-2">
            <h2
              class="text-3xl font-bold tracking-tighter sm:text-5xl text-primary-foreground"
            >
              Experience
            </h2>
            <p
              class="max-w-[900px] text-muted-foreground md:text-xl/relaxed lg:text-base/relaxed xl:text-xl/relaxed"
            >
              I have a diverse background in web development, with experience in
              both front-end and back-end technologies.
            </p>
          </div>
        </div>
        <div
          class="mx-auto grid max-w-5xl items-center gap-6 py-12 lg:grid-cols-2 lg:gap-12"
        >
          <div class="flex flex-col justify-center space-y-4">
            <ul class="grid gap-6">
              <li>
                <div class="grid gap-1">
                  <h3 class="text-xl font-bold text-primary-foreground">
                    Front-End Developer
                  </h3>
                  <p class="text-muted-foreground">Lorem ipsum</p>
                </div>
              </li>
              <li>
                <div class="grid gap-1">
                  <h3 class="text-xl font-bold text-primary-foreground">
                    Back-End Developer
                  </h3>
                  <p class="text-muted-foreground">
                    Developed scalable and secure server-side applications using
                    Node.js, Express, and PostgreSQL.
                  </p>
                </div>
              </li>
              <li>
                <div class="grid gap-1">
                  <h3 class="text-xl font-bold text-primary-foreground">
                    DevOps Engineer
                  </h3>
                  <p class="text-muted-foreground">
                    Automated deployment and infrastructure management using
                    tools like Docker, Kubernetes, and AWS.
                  </p>
                </div>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </section>
    <section id="projects" class="w-full py-12 md:py-24 lg:py-32 bg-background">
      <div class="container px-4 md:px-6">
        <div
          class="flex flex-col items-center justify-center space-y-4 text-center"
        >
          <div class="space-y-2">
            <h2
              class="text-3xl font-bold tracking-tighter sm:text-5xl text-primary-foreground"
            >
              Projects
            </h2>
            <p
              class="max-w-[900px] text-muted-foreground md:text-xl/relaxed lg:text-base/relaxed xl:text-xl/relaxed"
            >
              Check out some of the projects I've worked on to showcase my
              skills and experience.
            </p>
          </div>
        </div>
        <div
          class="mx-auto grid max-w-5xl items-center gap-6 py-12 lg:grid-cols-2 lg:gap-12"
        >
          <div class="flex flex-col justify-center space-y-4">
            <div
              class="rounded-lg border text-card-foreground shadow-sm bg-muted"
              data-v0-t="card"
            >
              <div class="flex flex-col space-y-1.5 p-6">
                <h3
                  class="whitespace-nowrap text-2xl font-semibold leading-none tracking-tight"
                >
                  E-Commerce Website
                </h3>
                <p class="text-sm text-muted-foreground">
                  A fully-featured e-commerce platform built with React,
                  Next.js, and Stripe.
                </p>
              </div>
              <div class="p-6"></div>
              <div class="flex items-center p-6">
                <a
                  class="inline-flex h-9 items-center justify-center rounded-md bg-primary px-4 py-2 text-sm font-medium text-primary-foreground shadow transition-colors hover:bg-primary/90 focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring disabled:pointer-events-none disabled:opacity-50"
                  href="#"
                  rel="ugc"
                >
                  View Project
                </a>
              </div>
            </div>
          </div>
          <div class="flex flex-col justify-center space-y-4">
            <div
              class="rounded-lg border text-card-foreground shadow-sm bg-muted"
              data-v0-t="card"
            >
              <div class="flex flex-col space-y-1.5 p-6">
                <h3
                  class="whitespace-nowrap text-2xl font-semibold leading-none tracking-tight"
                >
                  Portfolio Website
                </h3>
                <p class="text-sm text-muted-foreground">Lorem ipsum</p>
              </div>
              <div class="p-6"></div>
              <div class="flex items-center p-6">
                <a
                  class="inline-flex h-9 items-center justify-center rounded-md bg-primary px-4 py-2 text-sm font-medium text-primary-foreground shadow transition-colors hover:bg-primary/90 focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring disabled:pointer-events-none disabled:opacity-50"
                  href="#"
                  rel="ugc"
                >
                  View Project
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
    <section id="about" class="w-full py-12 md:py-24 lg:py-32 bg-muted">
      <div class="container px-4 md:px-6">
        <div class="grid gap-10 sm:px-10 md:gap-16 md:grid-cols-2">
          <div class="space-y-4">
            <h2
              class="lg:leading-tighter text-3xl font-bold tracking-tighter sm:text-4xl md:text-5xl xl:text-[3.4rem] 2xl:text-[3.75rem] text-primary-foreground"
            >
              About Me
            </h2>
            <p
              class="mx-auto max-w-[700px] text-muted-foreground md:text-xl/relaxed"
            >
              I'm a passionate front-end developer with a strong background in
              creating responsive and accessible web applications. I love
              exploring new technologies and staying up-to-date with the latest
              industry trends.
            </p>
            <a
              class="inline-flex h-9 items-center justify-center rounded-md bg-primary px-4 py-2 text-sm font-medium text-primary-foreground shadow transition-colors hover:bg-primary/90 focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring disabled:pointer-events-none disabled:opacity-50"
              href="#"
              rel="ugc"
            >
              Get in Touch
            </a>
          </div>
          <div class="flex flex-col items-start space-y-4"></div>
        </div>
      </div>
    </section>
    <section id="contact" class="w-full py-12 md:py-24 lg:py-32 bg-background">
      <div class="container px-4 md:px-6">
        <div
          class="flex flex-col items-center justify-center space-y-4 text-center"
        >
          <div class="space-y-2">
            <h2
              class="text-3xl font-bold tracking-tighter sm:text-5xl text-primary-foreground"
            >
              Get in Touch
            </h2>
            <p
              class="max-w-[900px] text-muted-foreground md:text-xl/relaxed lg:text-base/relaxed xl:text-xl/relaxed"
            >
              I'm always excited to connect with new people and discuss
              potential collaborations or projects. Feel free to reach out using
              the form below.
            </p>
          </div>
          <div class="mx-auto w-full max-w-sm space-y-2">
            <form class="flex flex-col gap-2">
              <input
                class="flex h-10 w-full rounded-md border border-input px-3 py-2 text-sm ring-offset-background file:border-0 file:bg-transparent file:text-sm file:font-medium placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:cursor-not-allowed disabled:opacity-50 max-w-lg flex-1 bg-muted text-muted-foreground"
                placeholder="Name"
                type="text"
              />
              <input
                class="flex h-10 w-full rounded-md border border-input px-3 py-2 text-sm ring-offset-background file:border-0 file:bg-transparent file:text-sm file:font-medium placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:cursor-not-allowed disabled:opacity-50 max-w-lg flex-1 bg-muted text-muted-foreground"
                placeholder="Email"
                type="email"
              />
              <textarea
                class="flex min-h-[80px] w-full rounded-md border border-input px-3 py-2 text-sm ring-offset-background placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:cursor-not-allowed disabled:opacity-50 max-w-lg flex-1 bg-muted text-muted-foreground"
                placeholder="Message"></textarea>
              <button
                class="inline-flex items-center justify-center whitespace-nowrap rounded-md text-sm font-medium ring-offset-background transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 hover:bg-primary/90 h-10 px-4 py-2 bg-primary text-primary-foreground"
                type="submit"
              >
                Submit
              </button>
            </form>
          </div>
        </div>
      </div>
    </section>
  </main>
  <footer
    class="flex flex-col gap-2 sm:flex-row py-6 w-full shrink-0 items-center px-4 md:px-6 border-t bg-muted"
  >
    <p class="text-xs text-muted-foreground">
      © 2024 John Doe. All rights reserved.
    </p>
    <nav class="sm:ml-auto flex gap-4 sm:gap-6">
      <a
        class="text-xs hover:underline underline-offset-4 text-muted-foreground"
        href="#"
        rel="ugc"
      >
        Terms of Service
      </a>
      <a
        class="text-xs hover:underline underline-offset-4 text-muted-foreground"
        href="#"
        rel="ugc"
      >
        Privacy
      </a>
    </nav>
  </footer>
</div>
